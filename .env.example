# Application
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lofty

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Worker API key (shared secret for Colab worker auth)
WORKER_API_KEY=lofty-colab-worker-2026

# Clerk Authentication (get keys at https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# Storage (MinIO / S3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lofty-tracks
STORAGE_USE_SSL=false
STORAGE_PUBLIC_ENDPOINT=localhost:9000

# Model (ACE-Step 1.5)
MODEL_NAME=ace-step-1.5
MODEL_DEVICE=cpu
ACE_STEP_ENABLED=true
ACE_STEP_MODEL_PATH=ACE-Step/Ace-Step1.5
ACE_STEP_CACHE_DIR=./ace_model_cache
ACE_STEP_DEFAULT_INFERENCE_STEPS=8
ACE_STEP_MAX_DURATION_SECONDS=600.0
MOCK_GPU=true

# Model (YuE)
YUE_ENABLED=true
YUE_STAGE1_MODEL=m-a-p/YuE-s1-7B-anneal-en-cot
YUE_STAGE2_MODEL=m-a-p/YuE-s2-1B-general
YUE_CACHE_DIR=./yue_model_cache
YUE_USE_4BIT=true
YUE_MAX_DURATION_SECONDS=60.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_BURST=3

# Frontend (Clerk keys for Docker build)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
