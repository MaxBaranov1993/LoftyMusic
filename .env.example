# Application
DEBUG=true
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lofty

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Clerk Authentication (get keys at https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json

# Storage (MinIO / S3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=lofty-tracks
STORAGE_USE_SSL=false
STORAGE_PUBLIC_ENDPOINT=localhost:9000

# Model
MODEL_NAME=facebook/musicgen-stereo-large
MODEL_CACHE_DIR=./model_cache
MODEL_DEVICE=cpu
MAX_DURATION_SECONDS=30.0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_BURST=3
